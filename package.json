{
  "name": "gramobase",
  "version": "1.0.12",
  "description": "Telegram as a free, infinite, production-grade backend database with a MongoDB-like ORM, hot-caching, JWT auth, WAL crash-recovery, and SSE realtime streams.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./migrations": {
      "types": "./dist/migrations/index.d.ts",
      "import": "./dist/migrations/index.js",
      "require": "./dist/migrations/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "bin": {
    "gramobase": "dist/bin/gramobase.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "telegram",
    "database",
    "backend",
    "orm",
    "storage",
    "free"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "latest",
    "bloom-filters": "^3.0.4",
    "chalk": "latest",
    "commander": "latest",
    "crypto-js": "latest",
    "dotenv": "latest",
    "eventemitter3": "latest",
    "inquirer": "latest",
    "jsonwebtoken": "latest",
    "kleur": "latest",
    "lru-cache": "^11.5.1",
    "node-telegram-bot-api": "latest",
    "ora": "latest",
    "p-queue": "latest",
    "p-retry": "latest",
    "zod": "latest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "latest",
    "@types/crypto-js": "latest",
    "@types/inquirer": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
