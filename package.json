{
  "name": "gramobase",
  "version": "1.0.11",
  "description": "Telegram as a free, infinite, production-grade backend database with a MongoDB-like ORM, hot-caching, JWT auth, WAL crash-recovery, and SSE realtime streams.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./migrations": {
      "types": "./dist/migrations/index.d.ts",
      "import": "./dist/migrations/index.js",
      "require": "./dist/migrations/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "bin": {
    "gramobase": "dist/bin/gramobase.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "telegram",
    "database",
    "backend",
    "orm",
    "storage",
    "free"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bloom-filters": "^3.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.0",
    "eventemitter3": "^5.0.1",
    "inquirer": "^9.2.0",
    "jsonwebtoken": "^9.0.0",
    "kleur": "^4.1.5",
    "lru-cache": "^10.2.0",
    "node-telegram-bot-api": "^0.66.0",
    "ora": "^8.0.1",
    "p-queue": "^8.0.1",
    "p-retry": "^6.2.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/inquirer": "^9.0.9",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
